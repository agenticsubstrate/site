          "capabilities": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "public_key_hex": {
            "description": "The agent public key, lowercase hex.",
            "pattern": "^[0-9a-f]+$",
            "type": "string"
          },
          "scheme": {
            "enum": [
              "ed25519",
              "ref-hmac"
            ],
            "type": "string"
          },
          "signature_hex": {
            "description": "Hex signature over the canonical request body by the agent key (signatureScheme).",
