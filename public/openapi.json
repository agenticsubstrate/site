            "type": "string"
          },
          "signature_hex": {
            "description": "Hex signature over the canonical request body by the agent key (signatureScheme).",
            "type": "string"
          }
        },
        "required": [
          "agent_id",
          "proposal_id",
          "signature_hex"
        ],
        "type": "object"
      },
      "jobs": {
